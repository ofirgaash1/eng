{
  "name": "subtitle-word-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:extension": "tsc --noEmit && vite build --config vite.extension.config.ts && vite build --config vite.extension.content.config.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "backup:compact": "node scripts/compact-backup.mjs",
    "sync:deploy": "wrangler deploy --config sync-worker/wrangler.toml",
    "sync:dev": "wrangler dev --config sync-worker/wrangler.toml"
  },
  "dependencies": {
    "dexie": "^4.0.4",
    "nanoid": "^4.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/node": "^20.11.28",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "jsdom": "^28.0.0",
    "playwright": "^1.48.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vitest": "^1.3.1",
    "wrangler": "^4.77.0"
  },
  "description": "Local-first tool for studying vocabulary while watching movies with subtitle files. The app parses SRT cues, tokenizes words, and highlights anything you've marked as unknown so you can focus on learning while you watch.",
  "main": "postcss.config.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ofirgaash1/eng.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ofirgaash1/eng/issues"
  },
  "homepage": "https://github.com/ofirgaash1/eng#readme"
}
